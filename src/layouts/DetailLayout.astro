---
const {
  title,
  section,
  label,
  description,
  resourceHref,
  resourceLabel = "打开文件",
} = Astro.props;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}｜Lucian</title>

    <style>
      :root {
        --text: #1f2933;
        --muted: #667085;
        --card: rgba(255, 255, 255, 0.78);
        --border: rgba(148, 163, 184, 0.28);
        --ink: #111827;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        color: var(--text);
        font-family: "Times New Roman", "SimSun", "宋体", serif;
        background:
          radial-gradient(circle at 20% 10%, rgba(191, 219, 254, 0.55), transparent 32%),
          radial-gradient(circle at 80% 15%, rgba(221, 214, 254, 0.42), transparent 30%),
          linear-gradient(180deg, #eef6fb 0%, #ffffff 42%, #f8fafc 100%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .page {
        width: min(980px, calc(100% - 40px));
        margin: 0 auto;
      }

      header {
        height: 76px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .brand {
        font-size: 22px;
        font-weight: 700;
        letter-spacing: 0.02em;
      }

      nav {
        display: flex;
        gap: 26px;
        font-size: 17px;
      }

      nav a {
        color: #334155;
      }

      nav a:hover {
        color: #2563eb;
      }

      main {
        padding: 46px 0 0;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        margin-bottom: 24px;
        color: #475569;
        font-size: 16px;
      }

      .back-link:hover {
        color: #2563eb;
      }

      .detail-hero,
      :global(.detail-section) {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 24px;
        box-shadow: 0 18px 50px rgba(15, 23, 42, 0.055);
        backdrop-filter: blur(16px);
      }

      .detail-hero {
        padding: 42px 46px;
      }

      .eyebrow {
        display: flex;
        align-items: center;
        gap: 12px;
        color: #64748b;
        font-size: 15px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .tag {
        padding: 5px 11px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.68);
        border: 1px solid var(--border);
        color: #475569;
        text-transform: none;
      }

      h1 {
        margin: 18px 0 16px;
        color: var(--ink);
        font-size: 42px;
        letter-spacing: -0.01em;
      }

      .description {
        max-width: 720px;
        margin: 0;
        color: #475569;
        font-size: 19px;
        line-height: 1.9;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 30px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 10px 16px;
        border-radius: 999px;
        border: 1px solid rgba(37, 99, 235, 0.24);
        background: rgba(37, 99, 235, 0.08);
        color: #1e3a8a;
        font-size: 16px;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
      }

      .button:hover {
        transform: translateY(-1px);
        box-shadow: 0 12px 28px rgba(30, 64, 175, 0.11);
      }

      .detail-body {
        display: grid;
        gap: 18px;
        margin-top: 22px;
      }

      :global(.detail-section) {
        padding: 30px 34px;
      }

      :global(.detail-section h2) {
        margin: 0 0 14px;
        color: #111827;
        font-size: 23px;
      }

      :global(.detail-section p) {
        margin: 0 0 14px;
        color: #475569;
        font-size: 17px;
        line-height: 1.95;
      }

      :global(.detail-section p:last-child) {
        margin-bottom: 0;
      }

      :global(.meta-list) {
        display: grid;
        gap: 10px;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      :global(.meta-list li) {
        display: grid;
        grid-template-columns: 120px 1fr;
        gap: 16px;
        color: #475569;
        font-size: 16px;
        line-height: 1.7;
      }

      :global(.meta-list strong) {
        color: #111827;
      }

      footer {
        text-align: center;
        padding: 52px 0 70px;
        color: #64748b;
        font-size: 15px;
      }

      @media (max-width: 760px) {
        header {
          height: auto;
          padding: 26px 0;
          flex-direction: column;
          gap: 18px;
        }

        nav {
          flex-wrap: wrap;
          justify-content: center;
          gap: 18px;
        }

        main {
          padding-top: 28px;
        }

        .detail-hero,
        :global(.detail-section) {
          border-radius: 20px;
        }

        .detail-hero {
          padding: 32px 26px;
        }

        h1 {
          font-size: 34px;
        }

        .description {
          font-size: 18px;
        }

        :global(.detail-section) {
          padding: 26px 24px;
        }

        :global(.meta-list li) {
          grid-template-columns: 1fr;
          gap: 2px;
        }
      }
    </style>
  </head>

  <body>
    <div class="page">
      <header>
        <a class="brand" href="/">Lucian's World</a>

        <nav>
          <a href="/#about">About</a>
          <a href="/#projects">Projects</a>
          <a href="/#courses">Courses</a>
          <a href="/#writings">Writings</a>
          <a href="/#music">Music</a>
        </nav>
      </header>

      <main>
        <a class="back-link" href="/">← 返回首页</a>

        <article class="detail-hero">
          <div class="eyebrow">
            <span>{section}</span>
            <span class="tag">{label}</span>
          </div>

          <h1>{title}</h1>
          <p class="description">{description}</p>

          {
            resourceHref && (
              <div class="actions">
                <a class="button" href={resourceHref} target="_blank">
                  {resourceLabel}
                </a>
              </div>
            )
          }
        </article>

        <div class="detail-body">
          <slot />
        </div>
      </main>

      <footer>
        © 2026 Lucian. 愿此处存放一些微光，也存放一些未完成的远方。
      </footer>
    </div>
  </body>
</html>
